# Cutagent infrastructure configuration.
#
# Every variable below maps to a field on the typed Settings object in
# packages/core/config (see build_settings()). Values shown are the BUILT-IN
# DEFAULTS — uncomment and override only what you need. Provider API keys are
# deliberately NOT here: they live in the SecretStore / ProviderProfile, never
# in env/Settings.

# ── Storage backend (settings.storage.*) ───────────────────────────────────
# Persistence backend: sqlalchemy | postgres | memory (memory is tests/demo only).
CUTAGENT_STORAGE_BACKEND=sqlalchemy
# Database URL. Required (no default) when the SQLAlchemy backend is active.
CUTAGENT_DATABASE_URL=postgresql+psycopg://cutagent:cutagent@127.0.0.1:55432/cutagent

# ── Durable object store (settings.object_store.*) ─────────────────────────
# Tiered store toggle: "1" = tiered (durable + ephemeral), "0" = durable only.
CUTAGENT_OBJECTSTORE_TIERED=1
# Durable backend: local | s3
CUTAGENT_OBJECTSTORE_BACKEND=local
# Durable bucket name (used by both local and s3 backends).
CUTAGENT_OBJECTSTORE_BUCKET=cutagent-local
# Filesystem root for the local durable backend.
CUTAGENT_LOCAL_OBJECTSTORE_PATH=.data/objectstore

# ── Durable S3/MinIO transport (settings.object_store.s3.*) ────────────────
# Only used when CUTAGENT_OBJECTSTORE_BACKEND=s3. Access/secret keys here are
# MinIO/OSS connection params (infra), not provider API secrets.
CUTAGENT_OBJECTSTORE_ENDPOINT=http://127.0.0.1:9000
CUTAGENT_OBJECTSTORE_ACCESS_KEY=
CUTAGENT_OBJECTSTORE_SECRET_KEY=
CUTAGENT_OBJECTSTORE_REGION=us-east-1
CUTAGENT_OBJECTSTORE_ADDRESSING_STYLE=path
CUTAGENT_OBJECTSTORE_MULTIPART_THRESHOLD_MB=8
CUTAGENT_OBJECTSTORE_MULTIPART_CHUNK_MB=8
CUTAGENT_OBJECTSTORE_MAX_CONCURRENCY=4
CUTAGENT_OBJECTSTORE_CONNECT_TIMEOUT=10
CUTAGENT_OBJECTSTORE_READ_TIMEOUT=120
CUTAGENT_OBJECTSTORE_MAX_ATTEMPTS=5

# ── Ephemeral object store (settings.object_store.ephemeral.*) ─────────────
# Scratch tier used when CUTAGENT_OBJECTSTORE_TIERED=1.
CUTAGENT_EPHEMERAL_OBJECTSTORE_BACKEND=local
CUTAGENT_EPHEMERAL_OBJECTSTORE_BUCKET=cutagent-ephemeral
# Local ephemeral root. Default: <system temp dir>/cutagent-ephemeral
# CUTAGENT_OBJECTSTORE_EPHEMERAL_PATH=/tmp/cutagent-ephemeral
# Ephemeral s3 connection params (only used when backend=s3).
CUTAGENT_EPHEMERAL_OBJECTSTORE_ENDPOINT=http://127.0.0.1:9000
CUTAGENT_EPHEMERAL_OBJECTSTORE_ACCESS_KEY=
CUTAGENT_EPHEMERAL_OBJECTSTORE_SECRET_KEY=
CUTAGENT_EPHEMERAL_OBJECTSTORE_REGION=us-east-1
CUTAGENT_EPHEMERAL_OBJECTSTORE_ADDRESSING_STYLE=path

# ── Workflow runtime + Temporal (settings.workflow.*) ──────────────────────
# Runtime: local | temporal
CUTAGENT_WORKFLOW_RUNTIME=local
CUTAGENT_TEMPORAL_ADDRESS=127.0.0.1:7233
CUTAGENT_TEMPORAL_NAMESPACE=default
CUTAGENT_TEMPORAL_TASK_QUEUE=cutagent-production

# ── Auth / registration policy (settings.auth.*) ───────────────────────────
# Open public self-service registration: true | false
CUTAGENT_REGISTRATION_OPEN=true
# Salt mixed into registration-code hashes (override in production).
CUTAGENT_REGISTRATION_CODE_SALT=local-dev-registration-code-salt

# ── Secret store location (settings.secret_store.*) ────────────────────────
# On-disk directory for the local dev secret envelope store (NOT the secrets
# themselves — those are owned by SecretStore).
CUTAGENT_SECRET_STORE_DIR=.data/secrets

# ── Media tooling (settings.media.*) ───────────────────────────────────────
# Explicit ffmpeg/ffprobe binary paths. Unset = resolve via PATH, then
# ~/.local/bin, then the bare command name.
# CUTAGENT_FFMPEG_BIN=
# CUTAGENT_FFPROBE_BIN=

# ── API process behaviour (settings.api.*) ─────────────────────────────────
# Disable the in-process outbox dispatcher background task: "1" disables it.
# CUTAGENT_DISABLE_BACKGROUND_DISPATCHER=
