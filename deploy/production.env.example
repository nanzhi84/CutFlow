# Cutagent PRODUCTION environment template (issue #66).
#
# Unlike the dev-friendly `.env.example` at the repo root, this file lists the
# values a production deploy MUST set so the fail-closed startup preflight
# (`scripts/preflight.py` / `validate_startup_settings`) passes. Setting
# CUTAGENT_ENV=production turns the checks below from advisory into hard startup
# failures. Secrets (provider API keys, DB password material) still live in the
# SecretStore / your secrets manager, never in this file.
#
# Validate before deploying:  CUTAGENT_ENV=production python scripts/preflight.py

# ── Deployment topology (settings.deployment.*) ────────────────────────────
CUTAGENT_ENV=production
# Number of API replicas behind the load balancer. >1 REQUIRES a shared Redis.
CUTAGENT_REPLICA_COUNT=1
# Set to 1 ONLY if the publishing CDP host is intentionally a machine-local
# proxy (小V猫 running on the deploy host). Otherwise point the CDP host at a
# real address below.
# CUTAGENT_PUBLISHING_LOCAL_PROXY=1

# ── Persistence ────────────────────────────────────────────────────────────
CUTAGENT_STORAGE_BACKEND=sqlalchemy
CUTAGENT_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@DB_HOST:5432/cutagent

# ── Object store (must be shared S3/MinIO, esp. for >1 replica / Temporal) ──
CUTAGENT_OBJECTSTORE_BACKEND=s3
CUTAGENT_OBJECTSTORE_ENDPOINT=https://oss.example.com
CUTAGENT_OBJECTSTORE_BUCKET=cutagent-prod
CUTAGENT_OBJECTSTORE_ACCESS_KEY=__set_me__
CUTAGENT_OBJECTSTORE_SECRET_KEY=__set_me__
# Temporal runtime REQUIRES a shared ephemeral object store (not node-local).
CUTAGENT_EPHEMERAL_OBJECTSTORE_BACKEND=s3
CUTAGENT_EPHEMERAL_OBJECTSTORE_BUCKET=cutagent-ephemeral

# ── Auth / registration (closed + non-default salt + no seeded admin) ───────
CUTAGENT_REGISTRATION_OPEN=false
CUTAGENT_REGISTRATION_CODE_SALT=__set_a_unique_random_salt__
# Disable the hardcoded local admin/viewer seed once a real admin exists.
CUTAGENT_SEED_LOCAL_AUTH=false
# Session cookie must be Secure in production (TLS terminated upstream).
CUTAGENT_AUTH_COOKIE_SECURE=true
# Enable ONLY behind a trusted proxy/LB that overwrites X-Forwarded-For.
# CUTAGENT_AUTH_TRUST_FORWARDED_FOR=true

# ── Cross-replica coordination (required when CUTAGENT_REPLICA_COUNT > 1) ───
# CUTAGENT_REDIS_URL=redis://redis-host:6379/0

# ── Provider safety ────────────────────────────────────────────────────────
# Second-check host allowlist for outbound provider calls.
CUTAGENT_ENFORCE_PROVIDER_HOST_ALLOWLIST=1
CUTAGENT_ALLOWED_API_HOSTS=api.vendor-a.com,api.vendor-b.com
# Leave CUTAGENT_ALLOW_SANDBOX_FALLBACK UNSET in production (no sandbox fallback).

# ── Workflow runtime ───────────────────────────────────────────────────────
CUTAGENT_WORKFLOW_RUNTIME=temporal
CUTAGENT_TEMPORAL_ADDRESS=temporal-host:7233

# ── Publishing CDP host (real host, unless PUBLISHING_LOCAL_PROXY=1 above) ──
# CUTAGENT_XIAOVMAO_CDP_HOST=cdp-host
# CUTAGENT_XIAOVMAO_CDP_PORT=9222
